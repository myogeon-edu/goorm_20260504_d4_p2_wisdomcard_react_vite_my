Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# === Security & Environment variables ===
# 개인정보 및 API 키 보호를 위해 필수 제외
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.env
auth.json
secrets.json

# === Development Tools ===
# Sublime Text
*.sublime-project
*.sublime-workspace

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (PyCharm 등)
.idea/

# === Python specific ===
# 파이썬 컴파일 및 가상환경 파일
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.python-version

# === Web / Frontend ===
# 패키지 매니저 및 빌드 결과물
node_modules/
dist/
build/
.npm
.eslintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage
server/data/cards.json
server/data/searchLog.json
server/data/tts/*.mp3



